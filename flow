        "func": "/**\n * ============================================================================\n * KWL-Steuerung - Einstellungen\n * ============================================================================\n */\n\nmsg.settings = {\n    // ============================================================================\n    // Basis-Einstellungen\n    // ============================================================================\n\n    \"debug\": false,\n    // Aktiviert ausführliche Debug-Ausgaben in Node-RED\n    // true = Detaillierte Logs über Entscheidungen, Sensoren, Berechnungen\n    // false = Nur Fehler und Warnungen\n\n    \"minRuntimeMinutes\": 20,\n    // Minimale Laufzeit in Minuten zwischen Änderungen von:\n    // - Bypass (auf/zu)\n    // - Betriebsmodus (Manuell/ECO-Zuluft/ECO-Abluft)\n    // - Lüftungsstufe (nur wenn flowRate.enabled = false)\n    // Schützt vor zu häufigem Schalten und mechanischem Verschleiß\n\n    \"nightMaxLevel\": 3,\n    // Maximale Lüftungsstufe nachts (1-4)\n    // Wird IMMER eingehalten, auch bei hohem CO₂\n    // Ausnahme: CO₂ kritisch (>1300 ppm) → Notfall-Modus\n\n    \"nightMaxFlowRate\": 225,\n    // Maximaler Volumenstrom nachts in m³/h\n    // Wird IMMER eingehalten (siehe nightMaxLevel)\n    // Reduziert Lautstärke während der Nachtruhe\n\n    // ============================================================================\n    // Volumenstrom-Einstellungen\n    // ============================================================================\n\n    \"flowRate\": {\n        \"enabled\": true,\n        // true = Volumenstrom-Modus (feine Regelung 80-300 m³/h)\n        // false = Stufen-Modus (klassisch 1-4: Feuchteschutz bis Intensiv)\n        // Bei true wird Lüftungsstufe automatisch auf 3 (Nennlüftung) gesetzt\n\n        \"min\": 80,\n        // Minimaler Volumenstrom in m³/h\n\n        \"max\": 300,\n        // Maximaler Volumenstrom in m³/h\n\n        \"step\": 5,\n        // Schrittweite für Volumenstrom-Anpassungen in m³/h\n        // Werte werden auf diese Schritte gerundet (z.B. 5 → 80, 85, 90...)\n\n        \"maxStepPerCycle\": 20,\n        // Maximale Änderung pro Zyklus (normalerweise 5 Minuten) in m³/h\n        // Verhindert abrupte Sprünge, sorgt für sanfte Übergänge\n        // Ausnahme: CO₂ kritisch → sofort maximaler Volumenstrom\n\n        \"scoreMultiplier\": 55\n        // Multiplikator für Score-zu-Volumenstrom Berechnung\n        // Formel: Volumenstrom = min + (Score × scoreMultiplier)\n        // Höherer Wert = stärkere Reaktion auf Score-Änderungen\n    },\n\n    // ============================================================================\n    // CO₂-Grenzwerte und Trendanalyse\n    // ============================================================================\n\n    \"co2\": {\n        \"trendRisingThreshold\": 30,\n        // CO₂-Anstieg in ppm pro Zyklus, ab dem \"steigend\" erkannt wird\n        // Wird für dynamische Schwellenwerte verwendet\n\n        \"trendFallingThreshold\": -20,\n        // CO₂-Abfall in ppm pro Zyklus, ab dem \"fallend\" erkannt wird\n        // Erlaubt Reduzierung der Lüftung bei sinkenden Werten\n\n        \"highThreshold\": 1100,\n        // Absoluter CO₂-Grenzwert in ppm für \"hoch\"\n        // Ab diesem Wert wird Lüftung verstärkt\n\n        \"highWithTrendThreshold\": 900,\n        // CO₂-Wert in ppm, der bei steigendem Trend als \"hoch\" gilt\n        // Verhindert Flattern bei Werten um die Hauptschwelle\n\n        \"criticalThreshold\": 1300,\n        // Kritischer CO₂-Wert in ppm → Notfall-Modus\n        // Ignoriert alle Limits (auch Nacht), maximale Lüftung\n\n        \"baseValue\": 800,\n        // Basis-CO₂-Wert für Score-Berechnung in ppm\n        // Werte darunter beeinflussen Score nicht\n\n        \"rangeValue\": 700\n        // Wertebereich für Score-Berechnung in ppm\n        // Formel: (CO₂ - baseValue) / rangeValue × Gewicht\n        // (800 + 700 = 1500 ppm entspricht maximalem CO₂-Score)\n    },\n\n    // ============================================================================\n    // Temperatur-Einstellungen\n    // ============================================================================\n\n    \"temperature\": {\n        \"outsideDeltaCooler\": 1,\n        // Temperaturdifferenz in °C, ab der Außenluft als \"kühler\" gilt\n        // Verwendet für Nachtkühlung und Bypass-Entscheidungen\n\n        \"outsideDeltaWarmer\": 1,\n        // Temperaturdifferenz in °C, ab der Außenluft als \"wärmer\" gilt\n        // Verwendet für Sommer-Betriebsmodi\n\n        \"hysteresisBand\": 0.3,\n        // Hysterese-Band in °C um Maximaltemperatur\n        // Verhindert ständiges Ein-/Ausschalten der Kühlfunktion\n        // Aktivierung: Innentemp > Max + 0.3°C\n        // Deaktivierung: Innentemp < Max - 0.3°C\n\n        \"nightCoolingMinDelta\": 2,\n        // Minimale Temperaturdifferenz in °C für Nachtkühlung\n        // Innentemperatur muss mind. 2°C wärmer als außen sein\n\n        \"nightCoolingStrongDelta\": 3,\n        // Temperaturdifferenz in °C für intensive Nachtkühlung\n        // Ab 3°C wird mit höchster Stufe gekühlt (mit CO₂-Check)\n        \"nightCoolingSeasons\": [\"spring\", \"summer\"]\n        // Nachtkühlung findet nur in aufgeführten Jahreszeiten statt\n    },\n\n    // ============================================================================\n    // Luftfeuchtigkeits-Einstellungen\n    // ============================================================================\n\n    \"humidity\": {\n        \"hysteresisBand\": 2\n        // Hysterese-Band in % um Maximalfeuchtigkeit\n        // Verhindert ständiges Ein-/Ausschalten der Entfeuchtung\n        // Aktivierung: Luftf. > Max + 2%\n        // Deaktivierung: Luftf. < Max - 2%\n    },\n\n    // ============================================================================\n    // Score-Gewichtungen\n    // ============================================================================\n\n    \"scoreWeights\": {\n        // Gewichtungsfaktoren für Multi-Faktor-Score-Berechnung\n        // Höherer Wert = stärkerer Einfluss auf Gesamt-Score\n\n        \"air\": 1.0,\n        // Gewicht für CO₂-basierten Luftqualitäts-Score\n        // Hauptfaktor für Lüftungsbedarf\n\n        \"humidityHigh\": 0.8,\n        // Gewicht wenn Luftfeuchtigkeit zu hoch\n        // Entfeuchtungsbedarf\n\n        \"humidityLow\": 0.6,\n        // Gewicht wenn Luftfeuchtigkeit zu niedrig\n        // Reduzierung der Lüftung zum Erhalt der Feuchtigkeit\n\n        \"tempMax\": 0.7,\n        // Gewicht wenn Temperatur über Maximum\n        // Kühlungsbedarf\n\n        \"tempMin\": 0.5\n        // Gewicht wenn Temperatur unter Sollwert\n        // Reduzierung der Lüftung zum Erhalt der Wärme\n    },\n\n    // ============================================================================\n    // Prioritäts-Anpassungen (aus Home Assistant)\n    // ============================================================================\n\n    \"priorityAdjustments\": {\n        // Faktoren für Benutzer-Prioritäten aus Home Assistant\n        // Positive Werte erhöhen Score/Lüftung, negative reduzieren\n\n        \"airQuality\": 0.3,\n        // Zusätzlicher Faktor für Priorität \"Luftqualität\"\n        // Verstärkt CO₂-Gewichtung um 30%\n\n        \"tempHigh\": -0.3,\n        // Score-Anpassung für Priorität \"Temperatur hoch\"\n        // Reduziert Lüftung, um Wärme zu halten\n\n        \"tempLow\": 0.4,\n        // Score-Anpassung für Priorität \"Temperatur runter\"\n        // Erhöht Lüftung bei kühler Außenluft\n\n        \"humidityHigh\": -0.3,\n        // Faktor für Priorität \"Feuchtigkeit hoch\"\n        // Reduziert Trockenheits-Score (weniger lüften bei zu trocken)\n\n        \"humidityLow\": 0.3,\n        // Faktor für Priorität \"Feuchtigkeit runter\"\n        // Verstärkt Feuchtigkeits-Score (mehr lüften bei zu feucht)\n\n        \"quiet\": 0.8,\n        // Multiplikator für Priorität \"Lautstärke\"\n        // Reduziert Gesamt-Score um 20%\n        // Zusätzlich: Hard-Cap bei Stufe 3 / 225 m³/h\n\n        \"dayBias\": 0.3,\n        // Score-Bonus tagsüber\n        // Aktivere Lüftung während des Tages\n\n        \"nightBias\": -0.2\n        // Score-Reduktion nachts\n        // Ruhigere Lüftung während der Nacht\n    },\n\n    // ============================================================================\n    // Boost-Werte (Volumenstrom-Anpassungen)\n    // ============================================================================\n\n    \"boosts\": {\n        // Feste Volumenstrom-Änderungen in m³/h für spezielle Situationen\n        // Nur aktiv im Volumenstrom-Modus (flowRate.enabled = true)\n\n        \"co2High\": 40,\n        // Boost bei hohem CO₂-Wert (+40 m³/h)\n\n        \"co2Falling\": -30,\n        // Reduktion bei fallendem CO₂ (-30 m³/h)\n        // Sanfte Rückführung zur Normallüftung\n\n        \"dehumidify\": 35,\n        // Boost bei aktiver Entfeuchtung (+35 m³/h)\n\n        \"nightCoolStrong\": 60,\n        // Boost bei intensiver Nachtkühlung (+60 m³/h)\n        // Nur wenn ΔT ≥ 3°C und CO₂ > 1200 ppm\n\n        \"nightCoolMedium\": 40,\n        // Boost bei mittlerer Nachtkühlung (+40 m³/h)\n        // Wenn ΔT ≥ 2°C\n\n        \"nightCoolSoft\": 20,\n        // Boost bei sanfter Nachtkühlung (+20 m³/h)\n\n        \"tempHighReduction\": 40,\n        // Reduktion bei Priorität \"Temperatur hoch\" (-40 m³/h max)\n        // Hält warme Luft im Haus\n\n        \"tempLowIncrease\": 50\n        // Boost bei Priorität \"Temperatur runter\" (+50 m³/h)\n        // Bringt kühle Luft ins Haus\n    },\n\n    // ============================================================================\n    // Dusch-Modus\n    // ============================================================================\n\n    \"showerMode\": {\n        \"enabled\": true,\n        // Aktiviert automatische Duscherkennung\n        // Überwacht zwei Badezimmer-Feuchtesensoren\n\n        \"humidityThresholdMild\": 10,\n        // Feuchtigkeitsanstieg in % für milde Duscherkennung\n        // Löst moderaten Boost aus\n\n        \"humidityThresholdStrong\": 20,\n        // Feuchtigkeitsanstieg in % für starke Duscherkennung\n        // Löst starken Boost aus (heißes Duschen, viel Dampf)\n\n        \"humidityFallingThreshold\": -5,\n        // Feuchtigkeitsabfall in % zur Erkennung von Duschende\n        // Beendet Boost-Modus automatisch\n\n        \"boostMild\": 30,\n        // Volumenstrom-Boost bei milder Duscherkennung (+30 m³/h)\n\n        \"boostStrong\": 60\n        // Volumenstrom-Boost bei starker Duscherkennung (+60 m³/h)\n    }\n};\n\nreturn msg;",
