        "name": "KWL – Auto‑Mode Check & Sensoren",
        "func": "/**\n * ============================================================================\n * kwl control - step 1: auto mode check & sensor data collection\n * ============================================================================\n * \n * tasks:\n * - check if auto mode and draft mode are correctly set\n * - read all relevant sensor data from home assistant\n * - validate completeness of sensor data\n * - abort flow if conditions are not met\n * \n * ============================================================================\n */\n\n// ============================================================================\n// settings and base configuration\n// ============================================================================\n\nconst states = global.get(\"homeassistant.homeSystem.states\") || {};\nconst settings = msg.settings || {};\nconst DEBUG = settings.debug === true;\n\n// entity ids for home assistant sensors\nconst CFG = {\n  topicBase: \"nodered/maico\",\n  \n  // environment sensors\n  season: \"select.times_season\",\n  dayWindow: \"sensor.tod_state\",\n  indoorTemp: \"sensor.ht_nr_indoor_temperature\",\n  outdoorTemp: \"sensor.ht_nr_outdoor_temperature\",\n  indoorRH: \"sensor.ht_nr_indoor_humidity\",\n  outdoorRH: \"sensor.ht_nr_outdoor_humidity\",\n  indoorAbsHum: \"sensor.ht_nr_indoor_abs_humidity\",\n  outdoorAbsHum: \"sensor.ht_nr_outdoor_abs_humidity\",\n  co2: \"sensor.ht_nr_indoor_co2\",\n  \n  // bathroom humidity (for shower mode)\n  bathroomHumidity1: \"sensor.ht_aq_13_1_humidity\",\n  bathroomHumidity2: \"sensor.ht_so_2_1_humidity\",\n  \n  // target values and limits\n  roomTempSet: \"number.kwl_1_temperature_target\",\n  roomTempMax: \"number.kwl_1_temperature_max\",\n  humidityMax: \"number.kwl_1_humidity_high\",\n  humidityMin: \"number.kwl_1_humidity_low\",\n  dewpointLimit: \"number.kwl_1_temperature_cooling\",\n  \n  // current kwl states\n  currentFanLevel: \"select.kwl_1_ventilation_mode\",\n  currentFlowRate: \"number.kwl_1_flow_rate_default\",\n  currentBypass: \"switch.kwl_1_ventilation_bypass\",\n  currentMode: \"select.kwl_1_operating_mode\",\n  filterAlarm: \"sensor.kwl_1_filter_replacement\",\n  priority: \"select.kwl_1_priority\",\n  \n  // control modes\n  autoMode: \"switch.kwl_1_ventilation_bypass_auto\",\n  draftMode: \"switch.kwl_1_ventilation_draft\"\n};\n\n// ============================================================================\n// helper functions for data conversion\n// ============================================================================\n\n// read value from home assistant state\nfunction get(id) {\n  return states[id]?.state ?? null;\n}\n\n// convert to number with fallback\nconst toNum = (id, fallback = null) => {\n  const value = Number(get(id));\n  return Number.isFinite(value) ? value : fallback;\n};\n\n// convert to string with fallback\nconst toStr = (id, fallback = \"\") => {\n  return String(get(id) ?? fallback);\n};\n\n// convert to boolean\nconst toBool = (id, fallback = false) => {\n  const value = String(get(id) ?? \"\").toLowerCase();\n  if ([\"on\", \"1\", \"true\", \"open\"].includes(value)) return true;\n  if ([\"off\", \"0\", \"false\", \"closed\"].includes(value)) return false;\n  return fallback;\n};\n\n// ============================================================================\n// normalization functions\n// ============================================================================\n\n// normalize season value\nconst normalizeSeason = (season) => {\n  const value = String(season || \"\").toLowerCase();\n  if ([\"winter\"].includes(value)) return \"winter\";\n  if ([\"spring\", \"frühling\", \"fruehling\"].includes(value)) return \"spring\";\n  if ([\"summer\", \"sommer\"].includes(value)) return \"summer\";\n  if ([\"autumn\", \"fall\", \"herbst\"].includes(value)) return \"autumn\";\n  return value;\n};\n\n// normalize day/night value\nconst normalizeDay = (day) => {\n  return [\"night\", \"nacht\"].includes(String(day).toLowerCase()) ? \"night\" : \"day\";\n};\n\n// convert ventilation level from text to number (1-4)\nconst mapVent = (vent) => {\n  const value = String(vent || \"\").toLowerCase();\n  if ([\"feuchteschutz\"].includes(value)) return 1;\n  if ([\"reduziert\"].includes(value)) return 2;\n  if ([\"nennlüftung\"].includes(value)) return 3;\n  if ([\"intensiv\"].includes(value)) return 4;\n  return Number(value) || 3;\n};\n\n// convert operating mode from text to internal\nconst mapMode = (mode) => {\n  const value = String(mode || \"\").toLowerCase();\n  if ([\"manuell\"].includes(value)) return \"balanced\";\n  if ([\"eco-zuluft\"].includes(value)) return \"supply_only\";\n  if ([\"eco-abluft\"].includes(value)) return \"exhaust_only\";\n  return \"balanced\";\n};\n\n// ============================================================================\n// collect sensor data\n// ============================================================================\n\nconst data = {\n  // base configuration\n  topicBase: CFG.topicBase,\n  season: normalizeSeason(toStr(CFG.season)),\n  dayWindow: normalizeDay(toStr(CFG.dayWindow)),\n  \n  // temperatures\n  indoorTemp: toNum(CFG.indoorTemp),\n  outdoorTemp: toNum(CFG.outdoorTemp),\n  \n  // humidity (relative)\n  indoorRH: toNum(CFG.indoorRH),\n  outdoorRH: toNum(CFG.outdoorRH),\n  \n  // humidity (absolute)\n  indoorAbsHumidity: toNum(CFG.indoorAbsHum),\n  outdoorAbsHumidity: toNum(CFG.outdoorAbsHum),\n  \n  // air quality\n  co2: toNum(CFG.co2),\n  \n  // bathroom humidity\n  bathroom1RH: toNum(CFG.bathroomHumidity1),\n  bathroom2RH: toNum(CFG.bathroomHumidity2),\n  \n  // target values\n  roomTempSet: toNum(CFG.roomTempSet),\n  roomTempMax: toNum(CFG.roomTempMax),\n  humidityMax: toNum(CFG.humidityMax, 60),\n  humidityMin: toNum(CFG.humidityMin, 40),\n  dewpointLimitTemp: toNum(CFG.dewpointLimit, 9),\n  \n  // current kwl values\n  currentFanLevel: mapVent(toStr(CFG.currentFanLevel)),\n  currentFlowRate: toNum(CFG.currentFlowRate, 150),\n  currentBypass: toBool(CFG.currentBypass, false),\n  currentMode: mapMode(toStr(CFG.currentMode, \"balanced\")),\n  filterAlarm: toBool(CFG.filterAlarm, false),\n  \n  // control\n  autoMode: toBool(CFG.autoMode, true),\n  draftMode: toBool(CFG.draftMode, false),\n  priority: toStr(CFG.priority, \"Ohne\")\n};\n\n// ============================================================================\n// auto mode check\n// ============================================================================\n\n// check if auto mode is active\nif (!data.autoMode) {\n  node.status({fill: \"grey\", shape: \"dot\", text: \"auto mode off\"});\n  if (DEBUG) {\n    node.warn(\"flow stopped: auto mode is disabled\");\n  }\n  return null;\n}\n\n// check if draft mode is inactive\nif (data.draftMode) {\n  node.status({fill: \"grey\", shape: \"dot\", text: \"draft mode on\"});\n  if (DEBUG) {\n    node.warn(\"flow stopped: draft mode is enabled\");\n  }\n  return null;\n}\n\n// ============================================================================\n// sensor data validation\n// ============================================================================\n\n// list of mandatory sensors\nconst requiredSensors = [\n  \"season\",\n  \"dayWindow\",\n  \"indoorTemp\",\n  \"outdoorTemp\",\n  \"indoorRH\",\n  \"indoorAbsHumidity\",\n  \"outdoorAbsHumidity\",\n  \"co2\",\n  \"roomTempSet\",\n  \"roomTempMax\"\n];\n\n// check for missing values\nconst missingSensors = requiredSensors.filter(key => {\n  return !data[key] && data[key] !== 0;\n});\n\ndata.sensorOk = missingSensors.length === 0;\n\n// ============================================================================\n// debug output\n// ============================================================================\n\nif (DEBUG && missingSensors.length > 0) {\n  node.warn(`missing sensor data: ${missingSensors.join(\", \")}`);\n}\n\nnode.status({\n  fill: \"green\",\n  shape: \"dot\",\n  text: `sensors ok | ${data.dayWindow}`\n});\n\nif (DEBUG && data.sensorOk) {\n  node.warn(\n    `collected data: ` +\n    `indoor ${data.indoorTemp}°C / ${data.indoorRH}% | ` +\n    `outdoor ${data.outdoorTemp}°C | ` +\n    `co₂ ${data.co2}ppm`\n  );\n}\n\n// ============================================================================\n// add metadata\n// ============================================================================\n\ndata._meta = {\n  missing: missingSensors,\n  timestamp: new Date().toISOString()\n};\n\n// ============================================================================\n// prepare output\n// ============================================================================\n\nmsg.payload = data;\nmsg.settings = settings;\nmsg.debug = \"auto+collect\";\n\nreturn msg;",
